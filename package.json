{
  "name": "wrapsocket-ts",
  "version": "1.0.0",
  "description": "Production-grade WebSocket client with auto-reconnection, heartbeat, and state management",
  "type": "module",
  "main": "dist/wrapsocket.js",
  "module": "dist/wrapsocket.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/wrapsocket.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --format=esm --outfile=dist/wrapsocket.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "websocket",
    "reconnect",
    "heartbeat",
    "typescript",
    "realtime"
  ],
  "author": "leoheung",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.20.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leoheung/wrapsocket-ts.git"
  }
}
